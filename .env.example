# ComplianceGPT Server Environment Variables

# Groq Cloud API Key (required for AI-powered assessments via openai/gpt-oss-120b)
GROQ_API_KEY=gsk_your-groq-api-key-here

# GenW.AI orchestration layer (optional; local scoring fallback remains available when unset)
GENW_API_BASE_URL=https://genw.example.com
GENW_API_KEY=genw_your_api_key_here
GENW_TIMEOUT_MS=45000
GENW_HEALTH_ENDPOINT=/health

# Server Port
PORT=3001

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
